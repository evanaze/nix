+async fn download_gguf_direct(
+    args: &Args,
+    progress_bar: ProgressBar,
+    verification: &GgufVerification,
+) -> Result<()> {
+    let backend = gguf::Gguf::new(Arc::new(dfdaemon::Config::default())).inspect_err(|err| {
+        error!("build gguf backend for direct download failed: {}", err);
+    })?;
+
+    let stat_response = backend
+        .stat(StatRequest {
+            task_id: Uuid::new_v4().to_string(),
+            url: verification.url.clone(),
+            http_header: Some(header_vec_to_headermap(args.header.clone())?),
+            timeout: verification.timeout,
+            client_cert: None,
+            object_storage: None,
+            hdfs: None,
+            hugging_face: Some(verification.hugging_face.clone()),
+            model_scope: None,
+        })
+        .await
+        .inspect_err(|err| {
+            error!("gguf stat failed during direct download: {}", err);
+        })?;
+
+    if !stat_response.success {
+        return Err(Error::BackendError(Box::new(BackendError {
+            message: stat_response
+                .error_message
+                .unwrap_or_else(|| "gguf stat failed during direct download".to_string()),
+            status_code: stat_response.http_status_code,
+            header: stat_response.http_header,
+        })));
+    }
+
+    let mut response = backend
+        .get(dragonfly_client_backend::GetRequest {
+            task_id: Uuid::new_v4().to_string(),
+            piece_id: Uuid::new_v4().to_string(),
+            url: verification.url.clone(),
+            range: None,
+            http_header: Some(header_vec_to_headermap(args.header.clone())?),
+            timeout: verification.timeout,
+            client_cert: None,
+            object_storage: None,
+            hdfs: None,
+            hugging_face: Some(verification.hugging_face.clone()),
+            model_scope: None,
+        })
+        .await
+        .inspect_err(|err| {
+            error!("gguf direct download failed: {}", err);
+        })?;
+
+    if !response.success {
+        return Err(Error::BackendError(Box::new(BackendError {
+            message: response
+                .error_message
+                .unwrap_or_else(|| "gguf direct download failed".to_string()),
+            status_code: response.http_status_code,
+            header: response.http_header,
+        })));
+    }
+
+    let download_path = percent_decode_str(args.url.path()).decode_utf8_lossy();
+    progress_bar.set_style(
+        ProgressStyle::with_template(
+            "{msg:.bold}\n[{elapsed_precise}] [{bar:60.green/red}] {percent:3}% ({bytes_per_sec:.red}, {eta:.cyan})",
+        )
+        .or_err(ErrorType::ParseError)?
+        .with_key("eta", |state: &ProgressState, w: &mut dyn Write| {
+            let _ = write!(w, "{:.1}s", state.eta().as_secs_f64());
+        })
+        .progress_chars("=>-"),
+    );
+    progress_bar.set_message(download_path.to_string());
+
+    if let Some(content_length) = stat_response.content_length {
+        progress_bar.set_length(content_length);
+    }
+
+    let mut file = OpenOptions::new()
+        .create(true)
+        .truncate(true)
+        .write(true)
+        .mode(dfget::DEFAULT_OUTPUT_FILE_MODE)
+        .open(&args.output)
+        .await
+        .inspect_err(|err| {
+            error!("open file {:?} failed: {}", args.output, err);
+        })?;
+
+    let mut downloaded = 0u64;
+    let mut buffer = vec![0u8; 1024 * 1024];
+    loop {
+        let read = match response.reader.read(&mut buffer).await {
+            Ok(read) => read,
+            Err(err) => {
+                error!(
+                    "read direct gguf response for {:?} failed: {}",
+                    args.output, err
+                );
+                fs::remove_file(&args.output)
+                    .await
+                    .inspect_err(|remove_err| {
+                        error!("remove file {:?} failed: {}", args.output, remove_err);
+                    })?;
+                return Err(Error::IO(err));
+            }
+        };
+
+        if read == 0 {
+            break;
+        }
+
+        if let Err(err) = file.write_all(&buffer[..read]).await {
+            error!("write direct gguf output {:?} failed: {}", args.output, err);
+            fs::remove_file(&args.output)
+                .await
+                .inspect_err(|remove_err| {
+                    error!("remove file {:?} failed: {}", args.output, remove_err);
+                })?;
+            return Err(Error::IO(err));
+        }
+
+        downloaded += read as u64;
+        progress_bar.set_position(downloaded);
+    }
+
+    if let Err(err) = file.flush().await {
+        error!("flush {:?} failed: {}", args.output, err);
+        fs::remove_file(&args.output)
+            .await
+            .inspect_err(|remove_err| {
+                error!("remove file {:?} failed: {}", args.output, remove_err);
+            })?;
+        return Err(Error::IO(err));
+    }
+
+    info!("flush {:?} success", args.output);
+
+    if let Err(err) = verify_downloaded_gguf(verification).await {
+        error!("gguf integrity check failed: {}", err);
+        fs::remove_file(&verification.output)
+            .await
+            .inspect_err(|remove_err| {
+                error!(
+                    "remove file {:?} failed: {}",
+                    verification.output, remove_err
+                );
+            })?;
+        return Err(err);
+    }
+
+    if !args.no_p2p {
+        let key = p2p::content_key(
+            args.url.as_str(),
+            &args.hf_revision,
+            args.hf_base_url.as_deref(),
+        );
+        register_gguf_seed(&args.p2p_tracker, &key, &args.output, args.seed_time);
+    }
+
+    progress_bar.finish_with_message("done (direct)");
+    Ok(())
+}
